# ─── Backend .env — copy to backend/.env and fill in ────────────────────
# This file is committed; backend/.env is gitignored.

# ─── Database (Supabase Postgres or local) ──────────────────────────────
# Format: postgresql+psycopg2://user:pass@host:port/dbname
# Production (Supabase pooler, transaction mode):
#   postgresql+psycopg2://postgres.<ref>:<pwd>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/compliance_dev

# Alembic needs session-mode (port 5432). Required only in production.
MIGRATION_DATABASE_URL=

# ─── Supabase (Auth + Storage) ──────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_STORAGE_BUCKET=call-audio

# ─── LLM providers — at least ONE required ──────────────────────────────
# Production default: OpenRouter + Claude Opus 4.7 (best accuracy for the
# 27-rejection compliance audit; pricier but acceptable for an internal tool).
# Override via ACTIVE_PROVIDER if you prefer the direct Anthropic API.
ACTIVE_PROVIDER=openrouter

OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-opus-4.7

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ─── Speech-to-text providers — at least ONE required ───────────────────
DEEPGRAM_API_KEY=
DEEPGRAM_BASE_URL=https://api.eu.deepgram.com
DEEPGRAM_LANGUAGE=en-GB

ASSEMBLYAI_API_KEY=
SPEECHMATICS_API_KEY=
GROQ_API_KEY=
COHERE_API_KEY=

# ─── Inngest (durable workflow engine) ──────────────────────────────────
# Sign up at https://inngest.com (free tier).
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
INNGEST_ENV=development

# ─── Object storage backend ─────────────────────────────────────────────
STORAGE_BACKEND=supabase   # supabase | s3
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=call-audio
S3_REGION=us-east-1
BACKUP_BUCKET=backups

# ─── CORS ───────────────────────────────────────────────────────────────
# Comma-separated list. Production: ONLY the production frontend domain.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── Admin / safety ─────────────────────────────────────────────────────
# Generate a strong random value (e.g. `openssl rand -hex 32`).
ADMIN_KEY=

# Dev convenience — every authenticated user becomes admin. NEVER true in prod.
# The lifespan startup guard refuses to boot if this is True with
# SENTRY_ENVIRONMENT=production.
DEV_ALL_ADMIN=false

# ─── Observability ──────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
PROMETHEUS_ENABLED=true

# ─── Feature flags ──────────────────────────────────────────────────────
USE_INNGEST_PIPELINE=false
USE_AGENT_ANALYZER=false
EMBEDDING_PREFILTER_ENABLED=false
EMBEDDING_PREFILTER_THRESHOLD=0.35
PRICING_MISMATCH_ENABLED=true
VULNERABLE_DETECTION_ENABLED=true
