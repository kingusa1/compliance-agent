backend/uploads/
backend/var/
*.sqlite
*.sqlite3
*.db

# ── Runtime settings override (2026-05-30 security audit) ────────────────
# Written by PUT /api/settings/model. Holds provider/model overrides — and,
# defensively, must NEVER contain API keys (the writer strips secrets). Keep
# it out of git regardless so a future regression can't leak a key via commit.
backend/runtime_settings.json

# ── Editor / OS noise ────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/

# ── Env files — never commit (creds + endpoints vary per machine) ────────
.env
.env.*
!.env.example
!*.env.example
backend/.env
backend/.env.*
!backend/.env.example
frontend-v3/.env
frontend-v3/.env.*
!frontend-v3/.env.local.example

# ── BRAIN/ is now LOCAL-ONLY (untracked 2026-05-23) ──────────────────────
# Per the owner's call: the vault may hold credentials and session-private
# context that must never leave the local disk. Pre-existing BRAIN history
# (up to and including commit e7a0a35) is in the public repo and must be
# treated as already-exposed for anything that was committed before today.
BRAIN/

# ── Logs ─────────────────────────────────────────────────────────────────
*.log
backend/*.log

# ── Vercel CLI link cache ────────────────────────────────────────────────
.vercel

# ── Supabase CLI scratch state (2026-05-24 wiring audit C9) ──────────────
# `supabase init` drops machine-local pointers under .supabase / supabase/.temp
# including pooler-url. The stub it writes for new projects ships port :5432
# (session-mode) — DO NOT inject as DATABASE_URL; prod requires :6543
# transaction-mode pooler. Keep these out of the repo so the wrong stub
# can't propagate via PR.
backend/supabase/.temp/
backend/supabase/.branches/
.supabase/
